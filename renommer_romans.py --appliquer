def cle_robuste(texte: str) -> str:
    """Produit une clef insensible aux accents, espaces, tirets et majuscules."""
    texte = unicodedata.normalize("NFKD", texte)
    texte = "".join(car for car in texte if not unicodedata.combining(car))
    return " ".join(re.findall(r"[a-z0-9]+", texte.casefold()))


def construire_catalogue() -> dict[str, Livre]:
    catalogue: dict[str, Livre] = {}
    for nom_source, auteur, titre in ENTREES:
        cle = cle_robuste(nom_source)
        if cle in catalogue:
            raise RuntimeError(f"Doublon interne dans le catalogue : {nom_source}")
        catalogue[cle] = Livre(auteur=auteur, titre=titre)
    return catalogue


CATALOGUE = construire_catalogue()


def slug(texte: str) -> str:
    """Transforme un auteur ou un titre en composant de nom de fichier lisible."""
    texte = unicodedata.normalize("NFC", texte.strip())
    texte = re.sub(r"[^\w]+", "_", texte, flags=re.UNICODE)
    return re.sub(r"_+", "_", texte).strip("_")


def nom_cible(livre: Livre, extension: str) -> str:
    return f"{slug(livre.auteur)}_{slug(livre.titre)}{extension.lower()}"


def cle_systeme(nom: str) -> str:
    """Approxime les comparaisons de noms de macOS (casse et normalisation)."""
    return unicodedata.normalize("NFD", nom).casefold()


def analyser(dossier: Path) -> tuple[list[tuple[Path, Path]], list[Path], list[str]]:
    noms_deja_renommes = {
        cle_systeme(nom_cible(livre, ".txt")) for livre in CATALOGUE.values()
    }
    fichiers = sorted(
        (
            p
            for p in dossier.rglob("*")
            if p.is_file() and p.suffix.casefold() == ".txt"
        ),
        key=lambda p: cle_systeme(str(p.relative_to(dossier))),
    )
    plan: list[tuple[Path, Path]] = []
    inconnus: list[Path] = []

    for source in fichiers:
        livre = CATALOGUE.get(cle_robuste(source.stem))
        if livre is None:
            # Permet de relancer le script sans erreur après un premier passage.
            if cle_systeme(source.name) in noms_deja_renommes:
                continue
            inconnus.append(source)
            continue
        cible = source.with_name(nom_cible(livre, source.suffix))
        if cle_systeme(source.name) != cle_systeme(cible.name):
            plan.append((source, cible))

    erreurs: list[str] = []
    cibles: dict[str, Path] = {}
    sources = {cle_systeme(str(source)) for source, _ in plan}

    for source, cible in plan:
        cle = cle_systeme(str(cible))
        autre = cibles.get(cle)
        if autre is not None:
            erreurs.append(
                f"Deux fichiers visent le même nom : {autre.name!r} et {source.name!r}"
            )
        cibles[cle] = source

        # Une cible qui est elle-même une source du plan sera libérée pendant
        # la première phase. Toute autre cible existante bloquerait l'opération.
        if cible.exists() and cle not in sources:
            erreurs.append(
                f"La cible existe déjà : {str(cible.relative_to(dossier))!r}"
            )

    return plan, inconnus, erreurs


def afficher(
    plan: list[tuple[Path, Path]], inconnus: list[Path], dossier: Path
) -> None:
    for source, cible in plan:
        print(
            f"{source.relative_to(dossier)}  ->  {cible.relative_to(dossier)}"
        )
    if inconnus:
        print("\nFichiers sans correspondance :", file=sys.stderr)
        for fichier in inconnus:
            print(f"  - {fichier.relative_to(dossier)}", file=sys.stderr)


def appliquer(plan: list[tuple[Path, Path]]) -> None:
    """Renomme en deux phases et tente un retour arriere en cas d'erreur."""
    jeton = uuid.uuid4().hex
    temporaires: list[tuple[Path, Path, Path]] = []

    try:
        for numero, (source, cible) in enumerate(plan):
            temporaire = source.with_name(f".renommage-{jeton}-{numero}.tmp")
            source.rename(temporaire)
            temporaires.append((source, temporaire, cible))

        termines: list[tuple[Path, Path, Path]] = []
        for source, temporaire, cible in temporaires:
            temporaire.rename(cible)
            termines.append((source, temporaire, cible))
    except OSError:
        # Les cibles deja creees sont remises sous leur ancien nom ; les autres
        # fichiers sont encore temporaires et sont egalement restaures.
        for source, temporaire, cible in reversed(temporaires):
            try:
                if cible.exists() and not source.exists():
                    cible.rename(source)
                elif temporaire.exists() and not source.exists():
                    temporaire.rename(source)
            except OSError:
                pass
        raise


def arguments() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Renomme les .txt du corpus sous la forme Auteur_Titre.txt."
    )
    parser.add_argument(
        "dossier",
        nargs="?",
        type=Path,
        default=DOSSIER_PAR_DEFAUT,
        help=f"dossier des romans (défaut : {DOSSIER_PAR_DEFAUT})",
    )
    parser.add_argument(
        "--appliquer",
        "--apply",
        action="store_true",
        help="effectue réellement les renommages (sinon : simple aperçu)",
    )
    return parser.parse_args()


def main() -> int:
    args = arguments()
    dossier = args.dossier.expanduser().resolve()

    if not dossier.is_dir():
        print(f"Erreur : dossier introuvable : {dossier}", file=sys.stderr)
        return 2

    plan, inconnus, erreurs = analyser(dossier)
    afficher(plan, inconnus, dossier)

    if erreurs:
        print("\nRenommage annulé :", file=sys.stderr)
        for erreur in erreurs:
            print(f"  - {erreur}", file=sys.stderr)
        return 2

    if inconnus:
        print(
            "\nRenommage annulé : complétez le catalogue avant de traiter "
            "les fichiers inconnus.",
            file=sys.stderr,
        )
        return 2

    if not plan:
        print("Aucun fichier à renommer.")
        return 0

    if not args.appliquer:
        print(f"\nAperçu : {len(plan)} fichier(s). Rien n'a été modifié.")
        print("Relancez avec --appliquer pour confirmer.")
        return 0

    try:
        appliquer(plan)
    except OSError as exc:
        print(f"Erreur pendant le renommage : {exc}", file=sys.stderr)
        return 1

    print(f"\nTerminé : {len(plan)} fichier(s) renommé(s).")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
